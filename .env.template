# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Azure / Microsoft Graph ──────────────────────────────────────────────────
# Tenant and client IDs from your Azure App Registration.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your-jira-api-token

# ── Git ───────────────────────────────────────────────────────────────────────
# Must match your git commit author name exactly (git log --format='%an').
GIT_AUTHOR=Your Name
# Root directory that contains your git repos (~ is expanded).
GIT_SEARCH_DIR=~/dev/yourorg
# How many directory levels deep to search for git repos (default: 5).
GIT_SEARCH_DEPTH=5

# ── Projectworks ─────────────────────────────────────────────────────────────
PW_BASE_URL=https://yourorg.projectworksapp.com
PW_USER_ID=your-user-id
PW_TASK_ID=your-task-id
# Session cookie — copy from browser DevTools (Network tab) after logging in.
# Expires periodically; refresh by copying a fresh value from your browser.
PW_COOKIE=your-session-cookie
